# Discord Bot Token (từ Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Danh sách Channel ID được phép sử dụng lệnh /quest
# Phân cách bằng dấu phẩy, ví dụ: 123456789,987654321
# Để trống = cho phép tất cả channel
ALLOWED_CHANNEL_IDS=

# Proxy xoay API Key (proxyxoay.shop)
# Để trống = không dùng proxy (kết nối trực tiếp)
PROXY_API_KEY=
